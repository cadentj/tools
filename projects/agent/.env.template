# Copy to .env, fill these in, then load with:
# set -a; source .env; set +a

# Fly app settings
FLY_APP_NAME=cc-bot
FLY_PRIMARY_REGION=ewr
FLY_VOLUME_NAME=agent_data
FLY_VOLUME_SIZE_GB=5

# Telegram bot settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_WEBHOOK_URL=https://cc-bot.fly.dev/telegram
TELEGRAM_WEBHOOK_SECRET=

# Cloudflare cron worker settings
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKER_NAME=hermes-cron
HERMES_CRON_JOBS_FILE=/data/repos/tools/projects/agent/jobs.md
# Optional; defaults to the first TELEGRAM_ALLOWED_USERS entry
HERMES_CRON_TRIGGER_USER_ID=

# GitHub access for cloning private repos onto the Fly volume
GH_TOKEN=

# Google API credentials
GOOGLE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=