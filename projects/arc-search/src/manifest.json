{
  "manifest_version": 3,
  "name": "Arc Search",
  "version": "1.0.0",
  "description": "Spotlight-style command bar for tabs, bookmarks, history, and more.",
  "permissions": ["tabs", "bookmarks", "history", "storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Arc Search settings",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-palette": {
      "suggested_key": {
        "default": "Ctrl+E",
        "mac": "Command+E"
      },
      "description": "Open command palette"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
